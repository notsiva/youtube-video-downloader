{
  "name": "youtube-downloader",
  "version": "1.0.0",
  "description": "",
  "main": "electron/main.js",
  "scripts": {
    "frontend": "cd frontend && npm run dev",
    "backend": "cd backend && npm run dev",
    "electron": "electron .",
    "dev": "concurrently \"npm run backend\" \"npm run frontend\" \"wait-on http://localhost:5173 && npm run electron\"",
    "build-electron": "electron-builder"
  },
  "build": {
    "appId": "com.notsivaa.youtube-downloader",
    "productName": "YouTube Downloader",
    "directories": {
      "output": "dist"
    },
    "extraResources": [
      {
        "from": "backend",
        "to": "backend"
      }
    ],
    "files": [
      "electron/**/*",
      "frontend/dist/**/*",
      "backend/**/*",
      "package.json"
    ],
    "linux": {
      "icon": "assets/icon.png",
      "target": [
        "AppImage"
      ],
      "category": "Utility"
    }
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "electron": "^42.4.1",
    "concurrently": "^10.0.3",
    "electron-builder": "^26.15.3",
    "wait-on": "^9.0.10"
  }
}
